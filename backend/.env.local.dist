# Copier ce fichier en .env.local et adapter les valeurs à ton environnement local
# cp .env.local.dist .env.local

APP_ENV=dev
APP_SECRET=analim-congress-secret-change-me-in-prod
DEFAULT_URI=http://localhost:8000

###> doctrine/doctrine-bundle ###
# PostgreSQL via Docker Compose (docker compose up -d depuis la racine du projet)
# Host: 127.0.0.1 | Port: 5433 | DB: congressistes | User: app | Password: secret
DATABASE_URL="postgresql://app:secret@127.0.0.1:5433/congressistes?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
# Générer les clés avec : php bin/console lexik:jwt:generate-keypair
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=analim-jwt-passphrase
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
# Mailpit (UI dispo sur http://localhost:8025) — lancé via Docker Compose
MAILER_DSN=smtp://localhost:1025
###< symfony/mailer ###
