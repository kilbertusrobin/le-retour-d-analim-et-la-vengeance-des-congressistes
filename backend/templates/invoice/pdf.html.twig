<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Facture #{{ invoice.id }}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: DejaVu Sans, sans-serif; font-size: 12px; color: #333; padding: 30px; }
        .header { border-bottom: 3px solid #2c5282; padding-bottom: 16px; margin-bottom: 24px; }
        .header h1 { font-size: 24px; color: #2c5282; }
        .header p { color: #666; font-size: 11px; margin-top: 4px; }
        .section { margin-bottom: 20px; }
        .section h2 { font-size: 13px; font-weight: bold; color: #2c5282; border-bottom: 1px solid #e2e8f0; padding-bottom: 6px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
        .info-grid { display: table; width: 100%; }
        .info-row { display: table-row; }
        .info-label { display: table-cell; font-weight: bold; width: 40%; padding: 3px 0; color: #4a5568; }
        .info-value { display: table-cell; padding: 3px 0; }
        table.items { width: 100%; border-collapse: collapse; margin-top: 8px; }
        table.items th { background: #ebf4ff; color: #2c5282; text-align: left; padding: 8px 10px; font-size: 11px; border: 1px solid #bee3f8; }
        table.items td { padding: 7px 10px; border: 1px solid #e2e8f0; font-size: 11px; }
        table.items tr:nth-child(even) td { background: #f7fafc; }
        .total-box { background: #ebf4ff; border: 2px solid #2c5282; border-radius: 4px; padding: 12px 16px; text-align: right; margin-top: 16px; }
        .total-box .label { font-size: 12px; color: #4a5568; }
        .total-box .amount { font-size: 20px; font-weight: bold; color: #2c5282; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 10px; font-weight: bold; }
        .badge-settled { background: #c6f6d5; color: #22543d; }
        .badge-pending { background: #feebc8; color: #7b341e; }
        .badge-printed { background: #bee3f8; color: #2a4365; }
        .footer { margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 12px; text-align: center; font-size: 10px; color: #999; }
    </style>
</head>
<body>

<div class="header">
    <h1>Congrès ANALIM — Facture #{{ invoice.id }}</h1>
    <p>
        Émise le {{ invoice.creationDate ? invoice.creationDate|date('d/m/Y') : 'N/A' }}
        &nbsp;|&nbsp;
        Statut :
        {% if invoice.settled %}
            <span class="badge badge-settled">RÉGLÉE</span>
        {% else %}
            <span class="badge badge-pending">NON RÉGLÉE</span>
        {% endif %}
        {% if invoice.print %}
            &nbsp;<span class="badge badge-printed">IMPRIMÉE</span>
        {% endif %}
    </p>
</div>

{% if invoice.attendee %}
<div class="section">
    <h2>Congressiste</h2>
    <div class="info-grid">
        <div class="info-row">
            <div class="info-label">Nom :</div>
            <div class="info-value">{{ invoice.attendee.lastName|upper }} {{ invoice.attendee.firstName }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Adresse :</div>
            <div class="info-value">{{ invoice.attendee.address }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Email :</div>
            <div class="info-value">{{ invoice.attendee.email }}</div>
        </div>
        <div class="info-row">
            <div class="info-label">Acompte versé :</div>
            <div class="info-value">{{ invoice.attendee.deposit|number_format(2, ',', ' ') }} €</div>
        </div>
        {% if invoice.attendee.organization %}
        <div class="info-row">
            <div class="info-label">Organisme payeur :</div>
            <div class="info-value">{{ invoice.attendee.organization.name }}</div>
        </div>
        {% endif %}
    </div>
</div>
{% endif %}

{% if invoice.attendee and invoice.attendee.hotel %}
<div class="section">
    <h2>Hébergement</h2>
    <table class="items">
        <thead>
            <tr>
                <th>Hôtel</th>
                <th>Catégorie</th>
                <th>Prix / nuit</th>
                <th>Nuits</th>
                <th>Petit-déjeuner</th>
                <th>Sous-total</th>
            </tr>
        </thead>
        <tbody>
            {% set hotel = invoice.attendee.hotel %}
            {% set nights = 5 %}
            {% set hotelTotal = hotel.nightPrice * nights %}
            {% set breakfast = invoice.attendee.breakfast ? hotel.breakfastPrice * nights : 0 %}
            <tr>
                <td>{{ hotel.name }}</td>
                <td>{{ hotel.category }}</td>
                <td>{{ hotel.nightPrice|number_format(2, ',', ' ') }} €</td>
                <td>{{ nights }}</td>
                <td>{{ invoice.attendee.breakfast ? breakfast|number_format(2, ',', ' ') ~ ' €' : '—' }}</td>
                <td>{{ (hotelTotal + breakfast)|number_format(2, ',', ' ') }} €</td>
            </tr>
        </tbody>
    </table>
</div>
{% endif %}

{% if invoice.attendee and invoice.attendee.sessionRegistration|length > 0 %}
<div class="section">
    <h2>Sessions</h2>
    <table class="items">
        <thead>
            <tr>
                <th>Session</th>
                <th>Date</th>
                <th>Durée (demi-journées)</th>
                <th>Prix</th>
            </tr>
        </thead>
        <tbody>
            {% for session in invoice.attendee.sessionRegistration %}
            <tr>
                <td>{{ session.label }}</td>
                <td>{{ session.startDate ? session.startDate|date('d/m/Y H:i') : '—' }}</td>
                <td>{{ session.durationHalfDays }}</td>
                <td>{{ session.price|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if invoice.attendee and invoice.attendee.activityRegistration|length > 0 %}
<div class="section">
    <h2>Activités</h2>
    <table class="items">
        <thead>
            <tr>
                <th>Activité</th>
                <th>Date</th>
                <th>Prix</th>
            </tr>
        </thead>
        <tbody>
            {% for activity in invoice.attendee.activityRegistration %}
            <tr>
                <td>{{ activity.label }}</td>
                <td>{{ activity.dateTime ? activity.dateTime|date('d/m/Y H:i') : '—' }}</td>
                <td>{{ activity.price|number_format(2, ',', ' ') }} €</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

<div class="total-box">
    <div class="label">MONTANT TOTAL À RÉGLER</div>
    <div class="amount">{{ invoice.totalAmount|number_format(2, ',', ' ') }} €</div>
    {% if invoice.attendee and invoice.attendee.deposit > 0 %}
    <div class="label" style="font-size:10px; margin-top:4px;">(acompte de {{ invoice.attendee.deposit|number_format(2, ',', ' ') }} € déjà déduit)</div>
    {% endif %}
</div>

{% if invoice.payments|length > 0 %}
<div class="section" style="margin-top: 20px;">
    <h2>Règlements</h2>
    <table class="items">
        <thead>
            <tr>
                <th>Date</th>
                <th>Montant</th>
                <th>Organisme payeur</th>
            </tr>
        </thead>
        <tbody>
            {% for payment in invoice.payments %}
            <tr>
                <td>{{ payment.paymentDate ? payment.paymentDate|date('d/m/Y') : '—' }}</td>
                <td>{{ payment.amount|number_format(2, ',', ' ') }} €</td>
                <td>{{ payment.organization ? payment.organization.name : '—' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

<div class="footer">
    Congrès National ANALIM — Maison des Ligues de Lorraine
</div>

</body>
</html>
